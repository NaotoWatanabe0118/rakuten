# ─── Rakuten Account ───────────────────────────────────────────────────────────
RAKUTEN_USERNAME=your_rakuten_id@example.com
RAKUTEN_PASSWORD=your_password_here

# ─── Discord Webhook ────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXXX/XXXXXXXXXXXX

# ─── Monitoring ─────────────────────────────────────────────────────────────────
# Stock check interval (seconds)
POLL_INTERVAL_SECONDS=60

# ─── Selenium ───────────────────────────────────────────────────────────────────
# Set 1 to run headless inside Docker
HEADLESS=1

# Chromeプロファイルのパス
# 【推奨】既存のログイン済みChromeプロファイルを指定するとログイン/2FAが不要になります
# macOSの場合（Chromeを完全に閉じてから実行すること）:
#   CHROME_USER_DATA_DIR=/Users/your_name/Library/Application Support/Google/Chrome/Default
# Dockerの場合（ボリュームでセッションを永続化）:
#   CHROME_USER_DATA_DIR=/tmp/chrome_profile
CHROME_USER_DATA_DIR=/tmp/chrome_profile

# Page load timeout (seconds)
SELENIUM_PAGE_TIMEOUT=30

# ─── Paths ──────────────────────────────────────────────────────────────────────
SEARCHES_FILE=data/searches.json
STATE_FILE=data/stock_state.json
COOKIES_FILE=data/cookies.json

# ─── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
